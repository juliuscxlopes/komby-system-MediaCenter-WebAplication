# URL base para as chamadas de API
# Apontando para o caminho que o Nginx está escutando
VITE_API_URL=/api
VITE_DATACENTER_WS_URL=/ws

# Nome da aplicação (opcional, útil para o título da página ou logs)
VITE_APP_NAME="Web Appliance"

# Versão do sistema
VITE_APP_VERSION=1.0.0

# Redis
REDIS_HOST=kombi-redis
REDIS_PORT=6379
REDIS_PASSWORD=kombsystemRedis
